    {
      "id": "biconvex_thick_efl",
      "description": "Effective focal length of a biconvex thick lens (R1=50, R2=-50, t=5, n=1.5) in air.",
      "target": "paraxialCard",
      "inputs": {
        "stack": {
          "id": "test-biconvex",
          "source": "manual",
          "surfaces": [
            {
              "radiusMm": 50,
              "thicknessAfterMm": 5,
              "materialAfter": "LENS",
              "refractiveIndexAfter": 1.5
            },
            {
              "radiusMm": -50,
              "thicknessAfterMm": 0,
              "materialAfter": "AIR",
              "refractiveIndexAfter": 1.0
            }
          ],
          "warnings": []
        },
        "nBefore": 1
      },
      "expected": {
        "effectiveFocalLengthMm": 50.84745762711864
      },
      "toleranceRel": 1e-10,
      "derivation": "Lensmaker's thick lens equation: 1/f = (n-1)[1/R1 - 1/R2 + (n-1)t/(n R1 R2)] = 0.5*(0.04 - 1/1500) = 59/3000, so f = 3000/59 ≈ 50.8474576271."
    },
    {
      "id": "biconvex_thick_bfl",
      "description": "Back focal length of the same biconvex thick lens.",
      "target": "paraxialCard",
      "inputs": {
        "stack": {
          "id": "test-biconvex",
          "source": "manual",
          "surfaces": [
            {
              "radiusMm": 50,
              "thicknessAfterMm": 5,
              "materialAfter": "LENS",
              "refractiveIndexAfter": 1.5
            },
            {
              "radiusMm": -50,
              "thicknessAfterMm": 0,
              "materialAfter": "AIR",
              "refractiveIndexAfter": 1.0
            }
          ],
          "warnings": []
        },
        "nBefore": 1
      },
      "expected": {
        "backFocalLengthMm": 49.15254237288136
      },
      "toleranceRel": 1e-10,
      "derivation": "BFL = f * [1 - (n-1)t/(n R1)] = (3000/59) * (29/30) = 2900/59 ≈ 49.15254237."
    },
    {
      "id": "biconvex_thick_ffl",
      "description": "Front focal length (signed distance from first surface) of the biconvex lens using the code's D/C formula.",
      "target": "paraxialCard",
      "inputs": {
        "stack": {
          "id": "test-biconvex",
          "source": "manual",
          "surfaces": [
            {
              "radiusMm": 50,
              "thicknessAfterMm": 5,
              "materialAfter": "LENS",
              "refractiveIndexAfter": 1.5
            },
            {
              "radiusMm": -50,
              "thicknessAfterMm": 0,
              "materialAfter": "AIR",
              "refractiveIndexAfter": 1.0
            }
          ],
          "warnings": []
        },
        "nBefore": 1
      },
      "expected": {
        "frontFocalLengthMm": -49.15254237288136
      },
      "toleranceRel": 1e-10,
      "derivation": "From system matrix: D = 1 + (n-1)t/(n R2) = 29/30, C = -1/f = -59/3000, so FFL = D/C = -2900/59 ≈ -49.15254237. The negative sign indicates the front focal point is 49.15 mm to the left of the first surface."
    },
